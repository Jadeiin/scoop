    "bin": "bin\\trtexec.exe",
    "extract_dir": "TensorRT-11.1.0.106",
    "env_add_path": "lib",
    "checkver": {
        "url": "https://github.com/NVIDIA/TensorRT",
        "regex": "TensorRT v(?<verhead>11\\.\\d+\\.\\d+)\\.(?<verpatch>\\d+)",
        "replace": "${verhead}.${verpatch}"

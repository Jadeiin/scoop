    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://developer.nvidia.com/downloads/compute/machine-learning/tensorrt/$matchVerhead/zip/TensorRT-Enterprise-$version-Windows-amd64-cuda-12.9-Release-external.zip"
            }
        },
        "extract_dir": "TensorRT-$version"
    }
}

    "license": {
        "identifier": "Cherry Studio 用户协议",
        "url": "https://github.com/CherryHQ/cherry-studio/blob/main/LICENSE"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.8.0/Cherry-Studio-1.8.0-x64-setup.exe#/dl.7z",
            "hash": "sha512:33da5e1f93c9e815f1682a8845d2b7047e77e5ad7c1c858cb98b997e4585dda9426912e8ee645572b0b15220d515d7283790942dcec47d7c22856af3b998fc33",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\" -Recurse"
            ]
        },
        "arm64": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.8.0/Cherry-Studio-1.8.0-arm64-setup.exe#/dl.7z",
            "hash": "sha512:b5ea7827a37712dcd48e579fc322a5351c6fb534a4a359275ce924b9c86784f5a91f60336e894be5ec4ef71b47934e1bbdaecc3993557ea403481be163e64ed5",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-arm64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\" -Recurse"
            ]
        }
    },
    "shortcuts": [
        [
            "Cherry Studio.exe",
            "Cherry Studio",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "github": "https://github.com/CherryHQ/cherry-studio"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v$version/Cherry-Studio-$version-x64-setup.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v$version/Cherry-Studio-$version-arm64-setup.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "$basename\\s+sha512:\\s+$base64"
        }
    }
}

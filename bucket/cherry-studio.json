    "license": {
        "identifier": "Cherry Studio 用户协议",
        "url": "https://github.com/CherryHQ/cherry-studio/blob/main/LICENSE"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.9.4/Cherry-Studio-1.9.4-x64-setup.exe#/dl.7z",
            "hash": "sha512:bb45d4c15cc6b8a45ffab5cf354ed8b9445e002f2a54e5c810d62a12e3dd9b0b4ca9ebaf888ddc1600b797b490ed9f38d6586a91bb9b209683a435417b39fb74",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\" -Recurse"
            ]
        },
        "arm64": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.9.4/Cherry-Studio-1.9.4-arm64-setup.exe#/dl.7z",
            "hash": "sha512:718c6141365fb0a41cbe560865c15d20f642d577d286eec29523df19d04b9ab3b5aa052bf91fb5c6ebc2ff34c8144605c4667eb62859e1ed8af35d6fe706b293",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-arm64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\" -Recurse"
            ]
        }
    },
    "shortcuts": [
        [
            "Cherry Studio.exe",
            "Cherry Studio",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "github": "https://github.com/CherryHQ/cherry-studio"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v$version/Cherry-Studio-$version-x64-setup.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v$version/Cherry-Studio-$version-arm64-setup.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "$basename\\s+sha512:\\s+$base64"
        }
    }
}

            "hash": "sha512:01c91d1cef2da64d2ddb64af596808fbc73b0c3ae8f9efad1c91440770d0a86ffa08949ea4e7ca6b039465970f949e0906c1abb45ddde0a55736cd787a6160d2",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\" -Recurse"

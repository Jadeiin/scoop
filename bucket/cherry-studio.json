            ]
        }
    },
    "shortcuts": [
        [
            "Cherry Studio.exe",
            "Cherry Studio",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "github": "https://github.com/CherryHQ/cherry-studio"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {

            "hash": "sha512:b6c702eb8bc6485ae8cc0ee97c710a9ab85ad9401570147abcaaf5445eeb19e4f7a5d02e78eb21a2d6106d3b32a9d63ca832a3b8c9e6d95110a6cdb1bea8034b",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\" -Recurse"
            ]
        },
        "arm64": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.9.1/Cherry-Studio-1.9.1-arm64-setup.exe#/dl.7z",
            "hash": "sha512:21011609dbf2c188a0d79f13894c810383ebb779a3599c809d57f8c21ae2767ec92816716ed00dd786d83d71c6d63bcb45c1426052ef00d97b86c2e225c03a2c",

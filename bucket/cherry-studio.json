            "hash": "sha512:c933853ac647e583d3925c146c6345f4f35e87f0f37664a17ebefef732a252353718ce3eab9fbf5e63e223b7004797cf48d8693b3f0eb7652db16a652baeb023",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\" -Recurse"
            ]
        },
        "arm64": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.8.2/Cherry-Studio-1.8.2-arm64-setup.exe#/dl.7z",
            "hash": "sha512:c99efa193f0bae7776a05e65d412cae8bcdd0682998bd47670eb19d3288de1bca0783b50afb57263c760747755030975783336fb2a956df0588c6f322c4f6083",

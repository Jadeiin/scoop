{
    "version": "1.9.0",
    "description": "🍒 Cherry Studio is a desktop client that supports for multiple LLM providers. Support deepseek-r1",
    "homepage": "https://cherry-ai.com/",
    "license": {
        "identifier": "Cherry Studio 用户协议",
        "url": "https://github.com/CherryHQ/cherry-studio/blob/main/LICENSE"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.9.0/Cherry-Studio-1.9.0-x64-setup.exe#/dl.7z",
            "hash": "sha512:970090445952afd3a13b642b1e344eaff655e1830b1fd4649adf718247aeeb3d2597f15f22f8079806771a8fb49b154fc29c2d4158de95632fa32fffed8efeaf",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\" -Recurse"
            ]
        },
        "arm64": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.9.0/Cherry-Studio-1.9.0-arm64-setup.exe#/dl.7z",
            "hash": "sha512:5f46b5d2d831da57cb18d4b28bd0d64ec135e762eb409f0dfa04bbbb48b7d998b473f25f011194e132fafc5014789d8c1a4b58b0dc8c5764927e0d86431cd251",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-arm64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\" -Recurse"
            ]
        }
    },
    "shortcuts": [
        [
            "Cherry Studio.exe",
            "Cherry Studio",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "github": "https://github.com/CherryHQ/cherry-studio"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v$version/Cherry-Studio-$version-x64-setup.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v$version/Cherry-Studio-$version-arm64-setup.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "$basename\\s+sha512:\\s+$base64"
        }
    }
}

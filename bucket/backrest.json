{
    "version": "1.13.0",
    "description": "Backrest is a web UI and orchestrator for restic backup.",
    "homepage": "https://github.com/garethgeorge/backrest",
    "license": "GPL-3.0-or-later",
    "depends": "restic",
    "architecture": {
        "64bit": {
            "url": "https://github.com/garethgeorge/backrest/releases/download/v1.13.0/backrest_Windows_x86_64.zip",
            "hash": "2e0d09fe1edb1faff6505810872441361749fb7511566a493ad142b9db00a51f"
        },
        "arm64": {
            "url": "https://github.com/garethgeorge/backrest/releases/download/v1.13.0/backrest_Windows_arm64.zip",
            "hash": "7d729fdeecc9aa00b54858d980835d267adbdab968a6ba4342d575542d918e00"
        }
    },
    "bin": "backrest.exe",
    "env_set": {
        "BACKREST_CONFIG": "$dir\\backrest\\config.json",
        "BACKREST_DATA": "$dir\\backrest\\data",
        "BACKREST_RESTIC_COMMAND": "$(appdir restic $global)\\current\\restic.exe"
    },
    "persist": "backrest",
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/garethgeorge/backrest/releases/download/v$version/backrest_Windows_x86_64.zip"
            },
            "arm64": {
                "url": "https://github.com/garethgeorge/backrest/releases/download/v$version/backrest_Windows_arm64.zip"
            }
        },
        "hash": {
            "url": "$baseurl/backrest_$version_checksums.txt"
        }
    }
}

{
    "version": "1.21.1",
    "description": "AI chat client for developers, with local model support, code highlighting, and LaTeX rendering",
    "homepage": "https://chatboxai.app",
    "license": "GPL-3.0-or-later",
    "url": "https://download.chatboxai.app/releases/Chatbox-1.21.1-Setup.exe#/dl.7z",
    "hash": "6eee2f536ba32336042fc7bdc6f2f90bb1d2c68ad24b3117d6f4689280c5e55c",
    "pre_install": [
        "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
        "Remove-Item \"$dir\\Unins*\", \"$dir\\`$PLUGINSDIR\" -Force -Recurse"
    ],
    "bin": "Chatbox.exe",
    "shortcuts": [
        [
            "Chatbox.exe",
            "Chatbox",
            "--user-data-dir=\"$dir\\data\""
        ]
    ],
    "persist": "data",
    "checkver": {
        "url": "https://download.chatboxai.app/releases/latest.yml",
        "regex": "version:\\s(?<version>[\\d.]+)"
    },
    "autoupdate": {
        "url": "https://download.chatboxai.app/releases/Chatbox-$version-Setup.exe#/dl.7z"
    }
}
